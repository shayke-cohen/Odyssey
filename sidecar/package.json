{
  "name": "odyssey-sidecar",
  "version": "0.1.0",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "ODYSSEY_DATA_DIR=/tmp/odyssey-test-$(date +%s) bun test",
    "test:unit": "ODYSSEY_DATA_DIR=/tmp/odyssey-test-$(date +%s) bun test test/unit/",
    "test:integration": "ODYSSEY_DATA_DIR=/tmp/odyssey-test-$(date +%s) bun test test/integration/",
    "test:api": "ODYSSEY_DATA_DIR=/tmp/odyssey-test-$(date +%s) bun test test/api/",
    "test:e2e": "bun test test/e2e/",
    "test:repo-all": "bash ../scripts/run-all-tests.sh"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@anthropic-ai/sdk": "^0.78.0",
    "nostr-tools": "^2.23.3"
  }
}
